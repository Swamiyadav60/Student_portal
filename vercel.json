{
  "redirects": [
    {
      "source": "/",
      "destination": "/student_referral/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/student_referral/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}